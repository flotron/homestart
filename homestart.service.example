[Unit]
Description=HomeStart app launcher
After=network-online.target docker.service
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/homestart
ExecStart=/usr/bin/python3 /opt/homestart/app.py
Environment=PORT=80
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
